{
  "name": "nexus-banking",
  "version": "0.1.0",
  "private": true,
  "description": "Demo portfolio net banking platform with user and master admin portals.",
  "workspaces": [
    "frontend/user-portal",
    "frontend/admin-portal",
    "backend"
  ],
  "scripts": {
    "dev:user": "npm --prefix frontend/user-portal run dev",
    "dev:admin": "npm --prefix frontend/admin-portal run dev",
    "dev:backend": "npm --prefix backend run start:dev",
    "build": "npm run build:user && npm run build:admin && npm run build:backend",
    "build:user": "npm --prefix frontend/user-portal run build",
    "build:admin": "npm --prefix frontend/admin-portal run build",
    "build:backend": "npm --prefix backend run build",
    "lint": "npm run lint:user && npm run lint:admin && npm run lint:backend",
    "lint:user": "npm --prefix frontend/user-portal run lint",
    "lint:admin": "npm --prefix frontend/admin-portal run lint",
    "lint:backend": "npm --prefix backend run lint",
    "typecheck": "npm run typecheck:user && npm run typecheck:admin && npm run typecheck:backend",
    "typecheck:user": "npm --prefix frontend/user-portal run typecheck",
    "typecheck:admin": "npm --prefix frontend/admin-portal run typecheck",
    "typecheck:backend": "npm --prefix backend run typecheck",
    "test": "npm run test:backend",
    "test:backend": "npm --prefix backend run test",
    "test:e2e": "npm run test:user:e2e && npm run test:admin:e2e",
    "test:user:e2e": "npm --prefix frontend/user-portal run e2e",
    "test:admin:e2e": "npm --prefix frontend/admin-portal run e2e",
    "audit": "node scripts/audit-gate.mjs",
    "format:check": "prettier --check . --ignore-path .prettierignore",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "check:connections": "node scripts/check-connections.mjs"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  }
}
