generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CustomerStatus {
  DRAFT
  KYC_REVIEW
  COMPLIANCE_REVIEW
  RISK_REVIEW
  BRANCH_MANAGER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum EmployeeRole {
  CEO
  BRANCH_MANAGER
  ASSISTANT_MANAGER
  RELATIONSHIP_MANAGER
  KYC_OFFICER
  COMPLIANCE_OFFICER
  RISK_OFFICER
  LOAN_OFFICER
  TREASURY_OFFICER
  FINANCE_OFFICER
  AUDITOR
  SUPPORT_OFFICER
  IT_ADMINISTRATOR
  SECURITY_ADMINISTRATOR
}

enum AccountType {
  SAVINGS
  CURRENT
  SALARY
  FIXED_DEPOSIT
}

enum CardType {
  DEBIT
  CREDIT
}

enum CardStatus {
  ACTIVE
  BLOCKED
  FROZEN
  REPLACEMENT_REQUESTED
}

enum TransferType {
  OWN_ACCOUNT
  INTERNAL
  NEFT_SIMULATION
  RTGS_SIMULATION
  IMPS_SIMULATION
  UPI_SIMULATION
  SCHEDULED
}

enum TransferStatus {
  DRAFT
  OTP_PENDING
  SCHEDULED
  PROCESSING
  COMPLETED
  FAILED
  RISK_REVIEW
  CANCELLED
}

model Customer {
  id             String         @id @default(uuid())
  customerNumber String         @unique
  fullName       String
  email          String         @unique
  phone          String         @unique
  status         CustomerStatus @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  accounts       Account[]
  cards          Card[]
  beneficiaries  Beneficiary[]
  transfers      Transfer[]

  @@index([status])
}

model Employee {
  id        String       @id @default(uuid())
  employeeCode String    @unique
  fullName  String
  email     String       @unique
  role      EmployeeRole
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  auditLogs AuditLog[]

  @@index([role])
}

model Branch {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  city      String
  state     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Account {
  id            String      @id @default(uuid())
  accountNumber String      @unique
  type          AccountType
  currency      String      @default("INR")
  balance       Decimal     @db.Decimal(18, 2)
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  createdAt     DateTime    @default(now())
  transfersFrom Transfer[]  @relation("SourceAccount")
  transfersTo   Transfer[]  @relation("DestinationAccount")
}

model Beneficiary {
  id            String   @id @default(uuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  nickname      String
  accountNumber String
  bankName      String
  ifsc          String
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Card {
  id                 String     @id @default(uuid())
  customerId          String
  customer            Customer  @relation(fields: [customerId], references: [id])
  type                CardType
  maskedNumber        String
  status              CardStatus @default(ACTIVE)
  atmEnabled          Boolean    @default(true)
  onlineEnabled       Boolean    @default(true)
  contactlessEnabled  Boolean    @default(true)
  internationalEnabled Boolean   @default(false)
  dailyLimit          Decimal    @db.Decimal(18, 2)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model Transfer {
  id                   String         @id @default(uuid())
  reference            String         @unique
  customerId            String
  customer              Customer       @relation(fields: [customerId], references: [id])
  sourceAccountId       String?
  sourceAccount         Account?       @relation("SourceAccount", fields: [sourceAccountId], references: [id])
  destinationAccountId  String?
  destinationAccount    Account?       @relation("DestinationAccount", fields: [destinationAccountId], references: [id])
  type                  TransferType
  status                TransferStatus @default(DRAFT)
  amount                Decimal        @db.Decimal(18, 2)
  scheduledFor          DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([type, status])
}

model AuditLog {
  id          String    @id @default(uuid())
  actorId     String?
  actor       Employee? @relation(fields: [actorId], references: [id])
  action      String
  entityType  String
  entityId    String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@index([entityType, entityId])
}
