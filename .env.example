# ==============================================================================
# Centralized Environment Variables Example for Nexus Banking Platform
# Copy this file to '.env' at root or the individual packages:
#   - Frontend (user-portal): frontend/user-portal/.env.local
#   - Frontend (admin-portal): frontend/admin-portal/.env.local
#   - Backend: backend/.env
# ==============================================================================

# --- APPLICATION CONFIG ---
NODE_ENV="development"
APP_ENV="local"
PORT="4000"
API_PORT="4000"
CORS_ORIGIN="http://localhost:3000,http://localhost:3002"
DEMO_BANKING_MODE="true"
BANKING_RAILS_MODE="simulation"
DEMO_ADMIN_EMAIL="admin@example.com"
DEMO_ADMIN_PASSWORD=""

# --- DATABASE (Neon PostgreSQL / Prisma) ---
DATABASE_URL=""
DIRECT_URL=""

# --- SECURITY / JWT / AUTH ---
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
SESSION_SECRET=""
BCRYPT_SALT_ROUNDS="12"
OTP_TTL_SECONDS="300"

# --- CACHE / UPSTASH REDIS ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- STORAGE / MINIO ---
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""
MINIO_BUCKET_KYC="kyc"
MINIO_BUCKET_STATEMENTS="statements"
MINIO_BUCKET_PHOTOS="photos"
MINIO_BUCKET_SIGNATURES="signatures"
MINIO_BUCKET_REPORTS="reports"

# --- EMAIL / BREVO ---
BREVO_API_KEY=""
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"
BREVO_SMTP_USER=""
BREVO_SMTP_PASSWORD=""
BREVO_FROM_EMAIL="noreply@example.com"
BREVO_FROM_NAME="Nexus Banking"

# --- OBSERVABILITY / SENTRY ---
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"

# --- RATE LIMITING ---
RATE_LIMIT_TTL_MS="60000"
RATE_LIMIT_MAX="100"

# --- FRONTEND (Next.js Public Variables) ---
NEXT_PUBLIC_APP_NAME="Nexus Banking"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"
NEXT_PUBLIC_DEMO_MODE="true"
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
NEXT_PUBLIC_DEMO_ADMIN_EMAIL="admin@example.com"
NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=""
SENTRY_AUTH_TOKEN=""
GRAFANA_ADMIN_PASSWORD=""
